---
import '@fontsource-variable/inter';
import '../styles/global.css'
import  SpeedInsights  from "@vercel/speed-insights/astro"
// Supports weights 100-900

import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import Analytics from '../components/Analytics.astro';

import { siteConfig } from "../config/site.js";
const canonicalURL = new URL(Astro.url.pathname, Astro.site)

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const { title, description, ogImage } = Astro.props
const socialImage = ogImage 
  ? new URL(ogImage, Astro.site) 
  : new URL('/og-image.jpg', Astro.site)
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
		<meta name="generator" content={Astro.generator} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
		
    <!-- SEO Meta Tags -->
    <title>{title ?? siteConfig.name}</title>
    <meta
      name="description"
      content={description ?? siteConfig.description}
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title ?? siteConfig.name} />
    <meta property="og:description" content={description ?? siteConfig.description} />
    <meta property="og:image" content={socialImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:domain" content={siteConfig.twitter.site} />
    <meta name="twitter:title" content={title ?? siteConfig.name} />
    <meta name="twitter:description" content={description ?? siteConfig.description} />
    <meta name="twitter:image" content={socialImage} />

	</head>
	<body class="text-base-content font-sans">
    <div data-theme="black" class="flex flex-col min-h-screen max-w-400 mx-auto px-4 md:px-16">
      <Header />
      <main class="grow"><slot /></main>
      <Footer />
    </div>
    <SpeedInsights/>
    <Analytics />
  </body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>