---
import { Image } from 'astro:assets';
const { image, title, slug } = Astro.props;
---

<article class="group">
  <a 
    class="rounded-xl"
    href={`/blog/${slug}`}>
    <Image
      src={`/media/blog/${slug}/${image}`}
      alt=""   
      width="800" 
      height="600"
      decoding="async"
      loading="lazy"
      class="rounded-xl object-cover w-full aspect-4/3"
    />
    <h3 class="text-lg font-medium mt-4">{title}</h3>
  </a>
</article>