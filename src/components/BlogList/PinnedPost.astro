---
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from 'astro:assets';

const blog: CollectionEntry<'blog'>[] = await getCollection("blog");

const pinned = blog
  .filter((post) => post.data.pinned && post.data.published)
  .sort(
    (a, b) =>
      new Date(b.data.published).getTime() -
      new Date(a.data.published).getTime()
  )[0];

const imagePath = `/media/blog/${pinned.data.slug}/${pinned.data.image}`;
---

{pinned && (
  <article class="space-y-6">
    <a 
      class="rounded-xl"
      href={`/blog/${pinned.data.slug}`}>

      <h2 class="text-3xl md:text-4xl font-medium leading-tight mb-5 text-balance">
        {pinned.data.title}
      </h2>

      <Image
        src={imagePath}
        alt={pinned.data.title}  
        width="800" 
        height="600"
        decoding="async"
        loading="lazy"
        class="rounded-xl object-cover w-full aspect-4/3"
      />

      <p class="text-lg secondary-text max-w-3xl mt-6 text-base-content/70">
        {pinned.data.description}
      </p>

    </a>
  </article>
)}