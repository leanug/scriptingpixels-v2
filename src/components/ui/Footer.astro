---
import XIcon from "../ui/icons/X.astro"
import { siteConfig } from "../../config/site.js";
---

<footer id="footer" class="w-full text-sm py-6">
  <!-- Row 1 -->
  <div class="flex flex-col md:flex-row justify-between items-center py-4 gap-4">
    <!-- Left: logo + links -->
    <div class="flex items-center space-x-4">
      <a href="/" class="flex items-center space-x-2">
        <img src="/logo-white.svg" alt="Logo" class="h-6">
      </a>
      <a href="/terms-of-service" class="hover:underline">Terms of Service</a>
      <a href="/privacy-policy" class="hover:underline">Privacy Policy</a>
    </div>
  </div>

  <!-- Row 2: Big title -->
  <div class="text-center my-6 md:my-20">
    <img src="/big-name.svg" alt="Logo" class="w-full">
  </div>

  <!-- Row 3 -->
  <div class="flex flex-col md:flex-row justify-between items-center py-4 gap-4">
    <div>© 2025 ScriptingPixels</div>
    <div class="flex flex-wrap items-center gap-4">
      <span>Created by</span>
      <img src="/media/authors/leandro-ubilla.webp" alt="Leandro Ubilla" class="h-8 w-8 rounded-md object-cover">
      <a href="https://www.leandroubilla.com" target="_blank" class="underline">
        Leandro Ubilla
      </a>
      <a href={siteConfig.social.x} target="_blank" class="inline-flex items-center gap-2 bg-white text-black px-3 py-1.5 rounded-md text-sm font-medium hover:bg-gray-100 transition">
        <XIcon size={22} />
        Follow me
      </a>
    </div>
  </div>
</footer>
